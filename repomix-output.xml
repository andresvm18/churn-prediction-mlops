        95.5,
        1146.0,
    ],
    [
        "Male",
        0,
        "No",
        "No",
        24,
        "Yes",
        "Yes",
        "DSL",
        "Yes",
        "No",
        "Yes",
        "No",
        "No",
        "No",
        "One year",
        "No",
        "Bank transfer (automatic)",
        55.0,
        1320.0,
    ],
